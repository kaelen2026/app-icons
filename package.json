{
  "name": "app-icons",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm lint:repo && pnpm lint:design && pnpm lint:md && pnpm lint:secrets && eslint . && biome check .",
    "lint:repo": "node scripts/lint-repo.mjs",
    "lint:design": "node scripts/lint-design.mjs",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:secrets": "secretlint \"**/*\"",
    "lint:dead-code": "knip",
    "quality": "pnpm test:coverage && pnpm lint && pnpm lint:dead-code && pnpm typecheck && pnpm build",
    "audit:deps": "pnpm audit --audit-level moderate",
    "deps:outdated": "pnpm outdated",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:prod": "playwright test --config playwright.prod.config.ts",
    "test:coverage": "pnpm test:unit:coverage && pnpm test:component:coverage",
    "test:watch": "vitest",
    "test:unit": "vitest run src/lib",
    "test:unit:coverage": "vitest run src/lib --coverage",
    "test:component": "vitest run src/components",
    "test:component:coverage": "vitest run src/components --coverage --config vitest.component.config.ts",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "node scripts/lint-design.mjs",
      "biome check --write --no-errors-on-unmatched",
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "knip": "^6.16.1",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "secretlint": "^13.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
